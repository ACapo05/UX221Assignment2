{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"color": "#FAFAF8",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#1C2B1E",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#2D6A4F",
					"name": "Accent 1",
					"slug": "accent-1"
				},
				{
					"color": "#D8F3DC",
					"name": "Accent 2",
					"slug": "accent-2"
				},
				{
					"color": "#1B4332",
					"name": "Accent 3",
					"slug": "accent-3"
				},
				{
					"color": "#525E58",
					"name": "Accent 4",
					"slug": "accent-4"
				},
				{
					"color": "#F0F7F2",
					"name": "Accent 5",
					"slug": "accent-5"
				},
				{
					"color": "#B7DEC0",
					"name": "Accent 6",
					"slug": "accent-6"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Georgia, 'Times New Roman', Times, serif",
					"name": "Serif",
					"slug": "serif"
				},
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Sans-serif",
					"slug": "system-sans-serif"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "clamp(1.125rem, 2vw, 1.375rem)",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "clamp(1.5rem, 3vw, 2rem)",
					"slug": "x-large"
				},
				{
					"name": "XX-Large",
					"size": "clamp(2rem, 5vw, 3rem)",
					"slug": "xx-large"
				}
			]
		},
		"layout": {
			"contentSize": "660px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "name": "Tiny",     "size": "0.75rem",              "slug": "20" },
				{ "name": "X-Small",  "size": "1.25rem",              "slug": "30" },
				{ "name": "Small",    "size": "2rem",                 "slug": "40" },
				{ "name": "Regular",  "size": "clamp(2rem,5vw,3rem)", "slug": "50" },
				{ "name": "Large",    "size": "clamp(3rem,7vw,5rem)", "slug": "60" },
				{ "name": "X-Large",  "size": "clamp(4rem,7vw,6rem)", "slug": "70" },
				{ "name": "XX-Large", "size": "clamp(5rem,10vw,8rem)","slug": "80" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans-serif)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.75"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontWeight": "600",
					"lineHeight": "1.35"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system-sans-serif)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent-1)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-3)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--accent-3)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent-1)",
					"text": "#ffffff"
				},
				"border": {
					"radius": "4px"
				},
				"typography": {
					"fontWeight": "600"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-3)",
						"text": "#ffffff"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--accent-3)",
						"text": "#ffffff"
					}
				}
			}
		}
	}
}
